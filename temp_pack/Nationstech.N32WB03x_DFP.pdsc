<?xml version="1.0" encoding="UTF-8"?>

<package schemaVersion="1.4.0" 
    xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:noNamespaceSchemaLocation="PACK.xsd">
    <vendor>Nationstech</vendor>
    <url>http://www.keil.com/pack/</url>
    <name>N32WB03X_DFP</name>

    <description>Nationstech N32WB03x Series Device Support, Drivers and Examples</description>

    <releases>
        <release version="1.4.0">
            Update firmware driver to SDK V1.4 version. Update FLM file and add device(chip) version
        </release>
    </releases>

    <keywords>
        <keyword>Nationstech</keyword>
        <keyword>Device Support</keyword>
        <keyword>N32WB03x</keyword>
        <keyword>N32</keyword>
    </keywords>


    <devices>
        <family Dfamily="N32WB03x Series" Dvendor="Nationstech:927">
            <processor Dcore="Cortex-M0" DcoreVersion="r0p1" Dfpu="0" Dmpu="0" Dendian="Little-endian"/>
            <description>
            </description>

            <subFamily DsubFamily="N32WB03x">
                <description>
Bluetooth LE 5.1, Up to 64MHz ARM Cortex-M0, 256KFlash, 48KB SRAM, 2xUSART, 1xLPUART, 1xI2C, 2xSPI, 3xTIMER, RTC, IWDG, WWDG, 1x 10bit 1.33Msps ADC.
                </description>
                <processor Dclock="64000000"/>
                <compile header="firmware/CMSIS/device/n32wb03x.h" define="N32WB03x USE_STDPERIPH_DRIVER"/>

<device Dname="N32WB031">
    <description>
&#xA;&#xD;
- Package:QFN32&#xA;&#xD;
- Clock:  64MHz&#xA;&#xD;
- Flash:  256KB/512KB&#xA;&#xD;
- SRAM:   48KB&#xA;&#xD;
- I/O:    21&#xA;&#xD;
- Voltage: 1.8V/2.32V~3.6V -40~+85°C&#xA;&#xD;
- Timer:  3&#xA;&#xD;
- RTC:    1&#xA;&#xD;
- ADC:    1x10bit with 8 channels&#xA;&#xD;
- USART:  2&#xA;&#xD;
- LPUART: 1&#xA;&#xD;
- SPI/I2S:2/2&#xA;&#xD;
- I2C:    1&#xA;&#xD;
- RTC:    1&#xA;&#xD;
- IWDG:   1&#xA;&#xD;
- WWDG:   1&#xA;&#xD;
- KEYSCAN:1&#xA;&#xD;
- CRC:    CRC16/CRC32&#xA;&#xD;
&#xA;&#xD;

    </description>
    <memory id="IRAM1" access="rw" start="0x20000000" size="0x8000" default="1" init="0" />
    <memory id="IROM1" access="rx" start="0x1000000" size="0x40000" default="1" startup="1" />
    <algorithm name="Flash/N32WB03x.FLM" start="0x1000000" size="0x40000" default="1" startup="1" />
    <debug svd="svd/N32WB03X.svd"/>
</device>

<device Dname="N32WB031KCQ6-1">
    <description>
&#xA;&#xD;
- Package:QFN32&#xA;&#xD;
- Clock:  64MHz&#xA;&#xD;
- Flash:  256KB&#xA;&#xD;
- SRAM:   48KB&#xA;&#xD;
- I/O:    21&#xA;&#xD;
- Voltage: 1.8V~3.6V -40~+85°C&#xA;&#xD;
- Timer:  3&#xA;&#xD;
- RTC:    1&#xA;&#xD;
- ADC:    1x10bit with 8 channels&#xA;&#xD;
- USART:  2&#xA;&#xD;
- LPUART: 1&#xA;&#xD;
- SPI/I2S:2/2&#xA;&#xD;
- I2C:    1&#xA;&#xD;
- RTC:    1&#xA;&#xD;
- IWDG:   1&#xA;&#xD;
- WWDG:   1&#xA;&#xD;
- KEYSCAN:1&#xA;&#xD;
- CRC:    CRC16/CRC32&#xA;&#xD;
&#xA;&#xD;

    </description>
    <memory id="IRAM1" access="rw" start="0x20000000" size="0x8000" default="1" init="0" />
    <memory id="IROM1" access="rx" start="0x1000000" size="0x40000" default="1" startup="1" />
    <algorithm name="Flash/N32WB03x.FLM" start="0x1000000" size="0x40000" default="1" startup="1" />
    <debug svd="svd/N32WB03X.svd"/>
</device>

<device Dname="N32WB031KEQ6-2">
    <description>
&#xA;&#xD;
- Package:QFN32&#xA;&#xD;
- Clock:  64MHz&#xA;&#xD;
- Flash:  512KB&#xA;&#xD;
- SRAM:   48KB&#xA;&#xD;
- I/O:    21&#xA;&#xD;
- Voltage: 2.32V~3.6V -40~+85°C&#xA;&#xD;
- Timer:  3&#xA;&#xD;
- RTC:    1&#xA;&#xD;
- ADC:    1x10bit with 8 channels&#xA;&#xD;
- USART:  2&#xA;&#xD;
- LPUART: 1&#xA;&#xD;
- SPI/I2S:2/2&#xA;&#xD;
- I2C:    1&#xA;&#xD;
- RTC:    1&#xA;&#xD;
- IWDG:   1&#xA;&#xD;
- WWDG:   1&#xA;&#xD;
- KEYSCAN:1&#xA;&#xD;
- CRC:    CRC16/CRC32&#xA;&#xD;
&#xA;&#xD;

    </description>
    <memory id="IRAM1" access="rw" start="0x20000000" size="0x8000" default="1" init="0" />
    <memory id="IROM1" access="rx" start="0x1000000" size="0x80000" default="1" startup="1" />
    <algorithm name="Flash/N32WB03x.FLM" start="0x1000000" size="0x80000" default="1" startup="1" />
    <debug svd="svd/N32WB03X.svd"/>
</device>

            </subFamily>
        </family>
    </devices>
        

    <conditions>
        <condition id="Compiler ARM">            <!-- conditions selecting ARM Compiler -->
            <require Tcompiler="ARMCC"/>
        </condition>

        <condition id="N32WB03x CMSIS Device">            <!-- conditions selecting Devices -->
            <description>Nationstech N32WB03x Series devices</description>
            <require Cclass ="CMSIS" Cgroup="CORE" Csub=""/>
            <require Dvendor="Nationstech:927" Dname="N32*"/>
        </condition>

        <condition id="N32WB03x STDPERIPH">
            <description>Nationstech N32WB03x Standard Peripherals Drivers</description>
            <require condition="N32WB03x CMSIS Device"/>
            <require Cclass="Device" Cgroup="StdPeriph Drivers" Csub="Framework"/>
        </condition>

        <condition id="N32WB03x STDPERIPH RCC">
            <description>Nationstech N32WB03x Standard Peripherals Drivers</description>
            <require condition="N32WB03x STDPERIPH"/>
            <require Cclass="Device" Cgroup="StdPeriph Drivers" Csub="RCC"/>
        </condition>

    </conditions>

    <components>
        <component Cclass="Device" Cgroup="Startup" Cversion="1.0.0" condition="N32WB03x CMSIS Device">
            <description>Startup File for Nationstech N32WB03x Series</description>
            <files>
                <!--  include folder -->
                <file category="include" name="firmware/CMSIS/device/"/>
                <file category="source" name="firmware/CMSIS/device/startup/startup_n32wb03x.s" attr="config" condition="N32WB03x CMSIS Device" version="1.0.0"/>
            </files>
        </component>

        <component Cclass="Device" Cgroup="System_N32WB03x" Cversion="1.0.1" condition="N32WB03x CMSIS Device">
            <description>System Clock Config File for Nationstech N32WB03x</description>
            <files>
                <!--  include folder -->
                <file category="include" name="firmware/CMSIS/device/"/>
                <file category="source" name="firmware/CMSIS/device/system_n32wb03x.c" attr="config" version="1.0.1"/>
            </files>
        </component>

        <component Cclass="Device" Cgroup="StdPeriph Drivers" Csub="Framework" Cversion="1.0.0" condition="N32WB03x STDPERIPH">
            <description>Standard Peripherals Drivers Framework</description>
            <RTE_Components_h>
        #define RTE_DEVICE_STDPERIPH_FRAMEWORK
            </RTE_Components_h>
            <files>
                <file category="include" name="firmware/n32wb03x_std_periph_driver/inc/"/>
                <file category="source" name="firmware/n32wb03x_std_periph_driver/src/misc.c"/>
            </files>
        </component>

        <component Cclass="Device" Cgroup="StdPeriph Drivers" Csub="ADC" Cversion="1.0.1" condition="N32WB03x STDPERIPH RCC">
            <description>Analog-to-digital converter (ADC) driver for N32WB03x</description>
            <RTE_Components_h>
        #define RTE_DEVICE_STDPERIPH_ADC
            </RTE_Components_h>
            <files>
                <file category="header" name="firmware/n32wb03x_std_periph_driver/inc/n32wb03x_adc.h"/>
                <file category="source" name="firmware/n32wb03x_std_periph_driver/src/n32wb03x_adc.c"/>
            </files>
        </component>

        <component Cclass="Device" Cgroup="StdPeriph Drivers" Csub="CRC" Cversion="1.0.0" condition="N32WB03x STDPERIPH RCC">
            <description>CRC calculation unit (CRC) driver for N32WB03x</description>
            <RTE_Components_h>
        #define RTE_DEVICE_STDPERIPH_CRC
            </RTE_Components_h>
            <files>
                <file category="header" name="firmware/n32wb03x_std_periph_driver/inc/n32wb03x_crc.h"/>
                <file category="source" name="firmware/n32wb03x_std_periph_driver/src/n32wb03x_crc.c"/>
            </files>
        </component>

        <component Cclass="Device" Cgroup="StdPeriph Drivers" Csub="DMA" Cversion="1.0.1" condition="N32WB03x STDPERIPH RCC">
            <description>DMA controller (DMA) driver for N32WB03x</description>
            <RTE_Components_h>
        #define RTE_DEVICE_STDPERIPH_DMA
            </RTE_Components_h>
            <files>
                <file category="header" name="firmware/n32wb03x_std_periph_driver/inc/n32wb03x_dma.h"/>
                <file category="source" name="firmware/n32wb03x_std_periph_driver/src/n32wb03x_dma.c"/>
            </files>
        </component>

        <component Cclass="Device" Cgroup="StdPeriph Drivers" Csub="EXTI" Cversion="1.0.1" condition="N32WB03x STDPERIPH RCC">
            <description>External interrupt/event controller (EXTI) driver for N32WB03x</description>
            <RTE_Components_h>
        #define RTE_DEVICE_STDPERIPH_EXTI
            </RTE_Components_h>
            <files>
                <file category="header" name="firmware/n32wb03x_std_periph_driver/inc/n32wb03x_exti.h"/>
                <file category="source" name="firmware/n32wb03x_std_periph_driver/src/n32wb03x_exti.c"/>
            </files>
        </component>

        <component Cclass="Device" Cgroup="StdPeriph Drivers" Csub="FLASH" Cversion="1.0.1" condition="N32WB03x STDPERIPH RCC">
            <description>QSPI Flash memory (QFLASH) driver for N32WB03x</description>
            <RTE_Components_h>
        #define RTE_DEVICE_STDPERIPH_QFLASH
            </RTE_Components_h>
            <files>
                <file category="header" name="firmware/n32wb03x_std_periph_driver/inc/n32wb03x_qflash.h"/>
                <file category="source" name="firmware/n32wb03x_std_periph_driver/src/n32wb03x_qflash.c"/>
            </files>
        </component>

        <component Cclass="Device" Cgroup="StdPeriph Drivers" Csub="GPIO" Cversion="1.0.1" condition="N32WB03x STDPERIPH RCC">
            <description>General-purpose I/O (GPIO) driver for N32WB03x</description>
            <RTE_Components_h>
        #define RTE_DEVICE_STDPERIPH_GPIO
            </RTE_Components_h>
            <files>
