        <component Cclass="Device" Cgroup="StdPeriph Drivers" Csub="IWDG" Cversion="1.0.0" condition="N32WB03x STDPERIPH">
            <description>Independent watchdog (IWDG) driver for N32WB03x</description>
            <RTE_Components_h>
        #define RTE_DEVICE_STDPERIPH_IWDG
            </RTE_Components_h>
            <files>
                <file category="header" name="firmware/n32wb03x_std_periph_driver/inc/n32wb03x_iwdg.h"/>
                <file category="source" name="firmware/n32wb03x_std_periph_driver/src/n32wb03x_iwdg.c"/>
            </files>
        </component>

        <component Cclass="Device" Cgroup="StdPeriph Drivers" Csub="LPUART" Cversion="1.0.1" condition="N32WB03x STDPERIPH RCC">
            <description>Low Power Universal asynchronous receiver transmitter (LPUART) driver for N32WB03x</description>
            <RTE_Components_h>
