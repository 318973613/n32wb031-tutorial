            </RTE_Components_h>
            <files>
                <file category="header" name="firmware/n32wb03x_std_periph_driver/inc/n32wb03x_lpuart.h"/>
                <file category="source" name="firmware/n32wb03x_std_periph_driver/src/n32wb03x_lpuart.c"/>
            </files>
        </component>

        <component Cclass="Device" Cgroup="StdPeriph Drivers" Csub="PWR" Cversion="1.0.1" condition="N32WB03x STDPERIPH RCC">
            <description>Power controller (PWR) driver for N32WB03x</description>
            <RTE_Components_h>
