                <file category="source" name="firmware/n32wb03x_std_periph_driver/src/n32wb03x_gpio.c"/>
            </files>
        </component>

        <component Cclass="Device" Cgroup="StdPeriph Drivers" Csub="I2C" Cversion="1.0.1" condition="N32WB03x STDPERIPH RCC">
            <description>Inter-integrated circuit (I2C) interface driver for N32WB03x</description>
            <RTE_Components_h>
        #define RTE_DEVICE_STDPERIPH_I2C
            </RTE_Components_h>
